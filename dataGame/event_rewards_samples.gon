cutscene "cutscenename" //plays a cutscene, returns to the event once the cutscene is done then shows the results screen

cutscene {
    cutscene "time_machine"
    skip_result_screen true //when cutscene is over, return to the map instead of going to the rewards screen. NOTE this will nullify event rewards that do things on clicking the end button
}