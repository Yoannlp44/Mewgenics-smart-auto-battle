Flying {
    name "PASSIVE_FLYING_NAME"
    desc "PASSIVE_FLYING_DESC"
    class Psychic

    1 {
        passives {
            Flying 1
            StatusOnUseElementAbility {
                element Gravity
                SpeedUp 1
            }
            ElementalManaCostReduction {
                element Gravity
                reduction 1
            }
        }
    }
    2 {
        desc "PASSIVE_FLYING2_DESC"
        passives {
            Flying 1
            ExtraMovePoints 1
            StatusOnUseElementAbility {
                element Gravity
                SpeedUp 2
            }
            ElementalManaCostReduction {
                element Gravity
                reduction 2
            }
        }
    }
}


