MadVisage {
    name "PASSIVE_MADVISAGE_NAME"
    desc "PASSIVE_MADVISAGE_DESC"
    class Psychic

    1 {
        passives {
            ForceSpecificInjury cha

            PassiveWhenAtFullMana {
                AddStatusToBasicAttack {
                    Madness 1
                }
            }
            PassiveAtStatThreshold {
                mode less_or_equal
                threshold {
                    cha 0
                }
                passives {
                    ExtraBasicAttacks 1
                }
            }
        }
    }
    2 {
        desc "PASSIVE_MADVISAGE2_DESC"

        passives {
