// Applique automatiquement les AI presets à chaque classe de base via innate_passives.
// innate_passives est auto-appliqué à tous les chats de la classe dès le début.

Hunter.merge {
    innate_passives {
        ReplaceBrain {
            brain GenericBrain
            decision_weights smart_hunter
            move_weights smart_hunter_move
        }
    }
}

