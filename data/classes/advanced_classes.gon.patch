// Applique automatiquement les AI presets à chaque classe avancée via innate_passives.
// innate_passives est auto-appliqué à tous les chats de la classe dès le début.

Butcher.merge {
    innate_passives {
        ReplaceBrain {
            brain GenericBrain
            decision_weights smart_butcher
            move_weights smart_butcher_move
        }
    }
}

