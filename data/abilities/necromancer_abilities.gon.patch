// =====================================================================
// PATCH OPTIMISÉ DE L'IA DU NÉCROMANCIEN - MAÎTRE DES CADAVRES ET SURVIE
// =====================================================================

// --- 1. DÉSACTIVATION DES SORTS SUICIDAIRES ET FRATRICIDES ---
// "AbsorbSoul" TUE l'allié ciblé. C'est inacceptable pour une IA.
AbsorbSoul.merge { damage_instance { ai_base_score -99999 } }
AbsorbSoul2.merge { damage_instance { ai_base_score -99999 } }

// "Flatline" TUE le Nécromancien. Interdit.
Flatline.merge { damage_instance { ai_base_score -99999 } }
Flatline2.merge { damage_instance { ai_base_score -99999 } }

// "Seppuku" TUE le Nécromancien (Bonus du passif Last Gasp).
Seppuku.merge { damage_instance { ai_base_score -99999 } }

// "SlitWrists" (Bonus du passif OneWithNothing) inflige des dégâts à soi-même.
SlitWrists.merge { damage_instance { ai_base_score -99999 } }

// "DemonicPact" inflige une blessure aléatoire au lanceur.
DemonicPact.merge { damage_instance { ai_base_score -99999 } }
DemonicPact2.merge { damage_instance { ai_base_score -99999 } }


// --- 2. GESTION DES SACRIFICES DE POINTS DE VIE (Risque de Vaporisation) ---
// Le Nécromancien ne doit utiliser ces sorts que s'il a beaucoup de santé.
// Si sa santé est basse, le score devient négatif pour éviter la mort.

BloodGeyser.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_HealthThreshold { threshold_percent 50% } Else { FlatAIBonus -999999 } } } } }
BloodGeyser2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_HealthThreshold { threshold_percent 50% } Else { FlatAIBonus -999999 } } } } }

SoulTransfer.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_HealthThreshold { threshold_percent 50% } Else { FlatAIBonus -999999 } } } } }
SoulTransfer2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_HealthThreshold { threshold_percent 50% } Else { FlatAIBonus -999999 } } } } }

DonateBlood.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_HealthThreshold { threshold_percent 50% } Else { FlatAIBonus -999999 } } } } }
DonateBlood2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_HealthThreshold { threshold_percent 50% } Else { FlatAIBonus -999999 } } } } }

TradeLife.merge { damage_instance { ai_base_score -5 } } // Échanger sa vie avec un allié est trop risqué algorithmiquement.
TradeLife2.merge { damage_instance { ai_base_score -5 } }


// --- 3. PRIORISATION DES RÉANIMATIONS ET DES INVOCATIONS (CANNON FODDER) ---
// Le Nécromancien doit inonder la carte de cadavres et de familiers pour protéger le groupe.
Reanimate.merge { damage_instance { ai_base_score 100 } }
Reanimate2.merge { damage_instance { ai_base_score 100 } }

AnimateDead.merge { damage_instance { ai_base_score 90 } }
AnimateDead2.merge { damage_instance { ai_base_score 90 } }

RaiseTheDead.merge { damage_instance { ai_base_score 80 } }
RaiseTheDead2.merge { damage_instance { ai_base_score 80 } }

SummonBones.merge { damage_instance { ai_base_score 75 } }
SummonBones2.merge { damage_instance { ai_base_score 75 } }

MaggotArmy.merge { damage_instance { ai_base_score 75 } }
MaggotArmy2.merge { damage_instance { ai_base_score 75 } }

SummonShade.merge { damage_instance { ai_base_score 70 } }
SummonShade2.merge { damage_instance { ai_base_score 70 } }

FleshGolem.merge { damage_instance { ai_base_score 85 } }
FleshGolem2.merge { damage_instance { ai_base_score 85 } }


// --- 4. GESTION DES COMPÉTENCES "AFTERLIFE" (QUAND LE NÉCROMANCIEN EST UN CADAVRE) ---
// L'IA doit utiliser ces compétences de manière agressive si elle est déjà morte (Cadavre), 
// car elle est techniquement invulnérable (jusqu'à sa résurrection ou vaporisation du cadavre).
CarrionShot_Afterlife.merge { damage_instance { ai_base_score 50 } }
CarrionShot_Afterlife2.merge { damage_instance { ai_base_score 50 } }

LifeDrain_Afterlife.merge { damage_instance { ai_base_score 50 } }
LifeDrain_Afterlife2.merge { damage_instance { ai_base_score 50 } }

CoffinFlop_Afterlife.merge { damage_instance { ai_base_score 50 } }
CoffinFlop_Afterlife2.merge { damage_instance { ai_base_score 50 } }

Seance_Afterlife.merge { damage_instance { ai_base_score 50 } }
Seance_Afterlife2.merge { damage_instance { ai_base_score 50 } }

DonateBlood_Afterlife.merge { damage_instance { ai_base_score 50 } }
DonateBlood_Afterlife2.merge { damage_instance { ai_base_score 50 } }

TradeLife_Afterlife.merge { damage_instance { ai_base_score -5 } } // Toujours risqué
TradeLife_Afterlife2.merge { damage_instance { ai_base_score -5 } }


// --- 5. CONTRÔLE DE FOULE ET SURVIE ---
// "Scare" (Peur et Repoussement) est parfait pour éloigner un Boss.
Scare.merge { damage_instance { ai_base_score 60 custom_additional_ai_weight avoid_redundant_debuffs } }
Scare2.merge { damage_instance { ai_base_score 60 custom_additional_ai_weight avoid_redundant_debuffs } }

// "GoLimp" (Immunité aux blessures) est excellent si le Nécromancien est ciblé.
GoLimp.merge { damage_instance { ai_base_score 40 effects { Conditional_Speculative { Conditional_SourceHasStatus { status TempInjuryImmunity FlatAIBonus -999999 } } } } }
GoLimp2.merge { damage_instance { ai_base_score 40 effects { Conditional_Speculative { Conditional_SourceHasStatus { status TempInjuryImmunity FlatAIBonus -999999 } } } } }

