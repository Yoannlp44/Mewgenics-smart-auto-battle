// =====================================================================
// PATCH OPTIMISÉ DE L'IA DU CHASSEUR (HUNTER) - ANTI-VAPORISATION
// =====================================================================

// --- 1. DÉSACTIVATION DES MANŒUVRES SUICIDAIRES ---
// Le Harpon attire le Chasseur au corps-à-corps de la cible. 
// On interdit FORMELLEMENT à l'IA d'utiliser le Harpon contre un Boss.
Harpoon.merge {
    damage_instance {
        effects {
            Conditional_Speculative {
                Conditional_Boss {
                    FlatAIBonus -999999
                }
            }
        }
    }
}
Harpoon2.merge {
    damage_instance {
        effects {
            Conditional_Speculative {
                Conditional_Boss {
                    FlatAIBonus -999999
                }
            }
        }
    }
}

// Vivisect est une attaque de mêlée (portée 1). 
// L'IA ne doit l'utiliser sur un boss QUE si les dégâts (5 par défaut) sont suffisants pour le tuer.
Vivisect.merge {
    damage_instance {
        effects {
            Conditional_Speculative {
                Conditional_Boss {
                    Conditional_HealthThreshold {
                        threshold_flat 5
                    } Else {
                        FlatAIBonus -999999
                    }
                }
            }
        }
    }
}
Vivisect2.merge {
    damage_instance {
        effects {
            Conditional_Speculative {
                Conditional_Boss {
                    Conditional_HealthThreshold {
                        threshold_flat 5
                    } Else {
                        FlatAIBonus -999999
                    }
                }
            }
        }
    }
}

// --- 2. PRIORISATION EXTRÊME DU HARCÈLEMENT ET DES PIÈGES ---
// On force l'IA à jeter ses pièges entre elle et les boss pour bloquer l'avancée (Kiting)
