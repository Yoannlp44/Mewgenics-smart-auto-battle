// =====================================================================
// PATCH OPTIMISÉ DE L'IA DU COLORLESS - SURVIE ET PROTECTION DES RESSOURCES
// =====================================================================

// --- 1. PROTECTION DU PORTEFEUILLE DU JOUEUR (ANTI-BANQUEROUTE) ---
// On interdit formellement à l'IA d'utiliser des compétences qui coûtent de l'or.
BuyCatnip.merge { damage_instance { ai_base_score -99999 } }
BuyCatnip2.merge { damage_instance { ai_base_score -99999 } }

VetVisit.merge { damage_instance { ai_base_score -99999 } }
VetVisit2.merge { damage_instance { ai_base_score -99999 } }

HireHitman.merge { spawn { ai_base_score -99999 } }
HireHitman2.merge { spawn { ai_base_score -99999 } }

SubwayRide.merge { damage_instance { ai_base_score -99999 } }
SubwayRide2.merge { damage_instance { ai_base_score -99999 } }

GymMembership.merge { damage_instance { ai_base_score -99999 } }
GymMembership2.merge { damage_instance { ai_base_score -99999 } }

Donate.merge { spawn { ai_base_score -99999 } }
Donate2.merge { spawn { ai_base_score -99999 } }


// --- 2. INTERDICTIONS DE L'AUTO-SABOTAGE ET DU SUICIDE ---
// Russian Roulette a 16% de chance de tuer l'utilisateur. Interdit.
RussianRoulette.merge { damage_instance { ai_base_score -99999 } }
RussianRoulette2.merge { damage_instance { ai_base_score -99999 } }

// PlayDead sort le chat du combat, le laissant vulnérable aux AoE ou ruinant l'aggro.
PlayDead.merge { damage_instance { ai_base_score -99999 } }
PlayDead2.merge { damage_instance { ai_base_score -99999 } }

// Rest et CatNap endorment le chat. Devant un boss, c'est la mort.
Rest.merge { damage_instance { ai_base_score -99999 } }
Rest2.merge { damage_instance { ai_base_score -99999 } }
CatNap.merge { damage_instance { ai_base_score -99999 } }
CatNap2.merge { damage_instance { ai_base_score 20 } } // Le NV2 de CatNap n'endort plus, il buff les stats. On l'autorise !

// Sorts chaotiques et destructeurs pour l'équipe
ForbiddenFart.merge { damage_instance { ai_base_score -99999 } }
ForbiddenFart2.merge { damage_instance { ai_base_score -99999 } }
ManaDrain.merge { damage_instance { ai_base_score -99999 } }
ManaDrain2.merge { damage_instance { ai_base_score -99999 } }
Metronome.merge { damage_instance { ai_base_score -99999 } }
Metronome2.merge { damage_instance { ai_base_score -99999 } }
LotteryShottery.merge { damage_instance { ai_base_score -99999 } }
LotteryShottery2.merge { damage_instance { ai_base_score -99999 } }
WasteTime.merge { damage_instance { ai_base_score -99999 } }
Contort.merge { damage_instance { ai_base_score -99999 } }


// --- 3. VÉRIFICATION DE FRAPPE LÉTALE (ATTAQUES DE MÊLÉE) ---
// Le Colorless est fragile. S'il frappe un boss au corps-à-corps, il doit être certain de l'achever.
Smack.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 2 } Else { FlatAIBonus -999999 } } } } } }
Smack2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 4 } Else { FlatAIBonus -999999 } } } } } }

// DexterousHit s'échelonne avec la Dextérité, trop variable pour une prédiction IA simple. Interdit au CaC des boss.
DexterousHit.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }
DexterousHit2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }

// Knead est une attaque de mêlée qui inflige des debuffs. Le risque de vaporisation est trop grand.
Knead.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }
Knead2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }


// --- 4. PRIORISATION DES BOUTONS D'URGENCE (CONTRÔLE DE FOULE ET REPOUSSEMENT) ---
// Swat fait reculer (Knockback). Excellent pour maintenir les boss à distance.
Swat.merge { damage_instance { ai_base_score 60 } }
Swat2.merge { damage_instance { ai_base_score 70 } }

// Hiss applique Peur (Fear) et ForceMoveAway. Un outil de survie massif.
Hiss.merge { damage_instance { ai_base_score 75 custom_additional_ai_weight avoid_redundant_debuffs } }
Hiss2.merge { damage_instance { ai_base_score 75 custom_additional_ai_weight avoid_redundant_debuffs } }

// Trip immobilise l'ennemi. Parfait pour le kiting.
Trip.merge { damage_instance { ai_base_score 65 } }
Trip2.merge { damage_instance { ai_base_score 65 } }

// Zap étourdit (Stun).
Zap.merge { damage_instance { ai_base_score 60 } }
Zap2.merge { damage_instance { ai_base_score 60 } }

// LookAtMe force l'ennemi à se retourner.
LookAtMe.merge { damage_instance { ai_base_score 50 } }
LookAtMe2.merge { damage_instance { ai_base_score 50 } }


// --- 5. OPTIMISATION DE LA DÉFENSE ---
// On efface les pénalités que l'IA avait sur ces sorts et on les booste pour que le Colorless se protège.
Block.merge { damage_instance { ai_base_score 40 custom_additional_ai_weight favor_if_unshielded } }
Block2.merge { damage_instance { ai_base_score 40 custom_additional_ai_weight favor_if_unshielded } }

