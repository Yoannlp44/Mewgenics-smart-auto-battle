// Colorless abilities AI patches

// ── SLEEP RISKS ──────────────────────────────────────────────────────────────

// Rest: self-buff that heals 10 HP BUT inflicts Sleep 1 turn — only use when actually hurt
Rest.merge {
    damage_instance {
        custom_additional_ai_weight must_heal_most_missing_health
    }
}

// Rest2: variant of Rest, same logic
Rest2.merge {
    damage_instance {
        custom_additional_ai_weight must_heal_most_missing_health
    }
}

// CatNap: Cleanse self + Sleep 1 — same risk as Rest, only use when actually hurt
// (CatNap2 overrides damage_instance with AllStatsUp 1, no sleep — do not patch CatNap2)
CatNap.merge {
    damage_instance {
        custom_additional_ai_weight must_heal_most_missing_health
    }
}

// ── NEAR-ENEMY BUFFS ─────────────────────────────────────────────────────────

// Brace: self-buff Brace for 1 turn — useless without an adjacent enemy
Brace.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
    }
}

// Brace2: self-buff Brace+Thorns for 1 turn — useless without an adjacent enemy
Brace2.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
    }
}

// Block: self-buff Shield — only useful when about to take hits
Block.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
    }
}

// Block2: variant of Block, same logic
Block2.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
    }
}

// GainThorns: permanent Thorns — only useful if enemies will attack you in melee
GainThorns.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy_soft
    }
}

// GainThorns2: variant of GainThorns, same logic (cheaper at mana 2)
GainThorns2.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy_soft
    }
}

