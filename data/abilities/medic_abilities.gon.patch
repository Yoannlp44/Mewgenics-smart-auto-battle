CircleOfProtection.merge { damage_instance { ai_base_score 75 } }
CircleOfProtection2.merge { damage_instance { ai_base_score 75 } }

GuardianAngel.merge { damage_instance { ai_base_score 65 } }
GuardianAngel2.merge { damage_instance { ai_base_score 65 } }

Stimulants.merge { damage_instance { ai_base_score 50 } } // Buff de vitesse utile.
Stimulants2.merge { damage_instance { ai_base_score 50 } }


// --- 5. SAUVETAGE ET RÉSURRECTION ---
// Les sorts d'urgence doivent avoir les scores les plus élevés du jeu pour surclasser l'attaque.
Revive.merge { damage_instance { ai_base_score 100 } }
Revive2.merge { damage_instance { ai_base_score 100 } }

Emergency.merge { damage_instance { ai_base_score 90 } }
Emergency2.merge { damage_instance { ai_base_score 90 } }


// --- 6. ATTAQUES À DISTANCE ET CONTRÔLE (Kiting) ---
// Ces sorts sont gardés organiquement, l'IA les utilisera si le groupe est en pleine santé.
