// =====================================================================
// PATCH OPTIMISÉ DE L'IA DU CLERC - SURVIE, BUFFS ET SOINS INTELLIGENTS
// =====================================================================

// --- 1. SÉCURISATION DES ATTAQUES DE MÊLÉE ---
// Le Clerc ne doit frapper un boss au CaC que s'il peut le tuer. 
// "OpenWounds" s'échelonne sur les PV manquants de la cible (jusqu'à 25/50 dégâts). 
// On interdit formellement son utilisation sur un boss sauf si c'est le coup de grâce.
OpenWounds.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 25 } Else { FlatAIBonus -999999 } } } } } }
OpenWounds2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 50 } Else { FlatAIBonus -999999 } } } } } }


// --- 2. INTERDICTION DES SUICIDES DE SOUTIEN ---
// "BornAgain" endort le Clerc pour 4 tours. Devant un Boss, c'est la mort garantie du soigneur.
// L'IA Autobattler ne peut pas gérer ce niveau de vulnérabilité. À DÉSACTIVER.
BornAgain.merge { damage_instance { ai_base_score -99999 } }
BornAgain2.merge { damage_instance { ai_base_score -99999 } }


// --- 3. OPTIMISATION DES SOINS (NE PAS GASPILLER LE MANA) ---
// On force l'IA à ne soigner que les cibles qui en ont VRAIMENT besoin 
// et on donne un très haut score pour prioriser la survie de l'équipe.
RangedHeal.merge { damage_instance { ai_base_score 70 custom_additional_ai_weight must_heal_most_missing_health } }
RangedHeal2.merge { damage_instance { ai_base_score 70 custom_additional_ai_weight must_heal_most_missing_health } }

MeleeHeal.merge { damage_instance { ai_base_score 60 custom_additional_ai_weight must_heal_most_missing_health } }
MeleeHeal2.merge { damage_instance { ai_base_score 60 custom_additional_ai_weight must_heal_most_missing_health } }

HealingFall.merge { damage_instance { ai_base_score 60 custom_additional_ai_weight must_heal_most_missing_health } }
HealingFall2.merge { damage_instance { ai_base_score 60 custom_additional_ai_weight must_heal_most_missing_health } }

RallyCharge.merge { damage_instance { ai_base_score 50 custom_additional_ai_weight must_heal_most_missing_health } }
RallyCharge2.merge { damage_instance { ai_base_score 50 custom_additional_ai_weight must_heal_most_missing_health } }

Booster.merge { damage_instance { ai_base_score 40 } } // Soigne moins, mais donne des stats, score plus bas.
Booster2.merge { damage_instance { ai_base_score 40 } }

HealingSalve.merge { damage_instance { ai_base_score 30 } } // Regen lente, score modéré.
HealingSalve2.merge { damage_instance { ai_base_score 30 } }


// --- 4. PRIORISATION DES BUFFS MAJEURS ET DE LA PROTECTION ---
// Si personne n'a besoin d'être soigné, le clerc doit Buffer ou se protéger !
Zealot.merge { damage_instance { ai_base_score 80 custom_additional_ai_weight favor_if_unshielded } }
Zealot2.merge { damage_instance { ai_base_score 80 custom_additional_ai_weight favor_if_unshielded } }

Ethereal.merge { damage_instance { ai_base_score 80 custom_additional_ai_weight favor_if_unshielded } }
