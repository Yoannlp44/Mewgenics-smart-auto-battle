ShoddyJetpack2.merge { damage_instance { ai_base_score -99999 } }

EjectButton.merge { damage_instance { ai_base_score -99999 } }
EjectButton2.merge { damage_instance { ai_base_score -99999 } }

// FreshOffTheForge brûle le Bricoleur. Le bouclier gagné ne vaut pas le statut de Brûlure.
