// --- 1. DÉSACTIVATION DES INVENTIONS DANGEREUSES ET SUICIDAIRES ---
// Shockwave touche TOUT LE MONDE sur la carte, y compris tes propres chats. Interdit.
Shockwave.merge { damage_instance { ai_base_score -99999 } }
Shockwave2.merge { damage_instance { ai_base_score -99999 } }

// Ces gadgets ont des effets de téléportation aléatoire ou explosent sur le lanceur.
