// =====================================================================
// PATCH OPTIMISÉ DE L'IA DU TANK - MUR INFRANCHISSABLE ET PROTECTEUR
// =====================================================================

// --- 1. PRIORISATION ABSOLUE DE L'AGGRO (PROVOCATION) ---
// Ces capacités forcent les Boss à attaquer le Tank, sauvant ainsi le reste de l'équipe.
// L'IA doit les utiliser dès qu'un ennemi est à portée.
Taunt.merge { damage_instance { ai_base_score 80 } }
Taunt2.merge { damage_instance { ai_base_score 80 } }

DrawAttention.merge { damage_instance { ai_base_score 75 } }
DrawAttention2.merge { damage_instance { ai_base_score 75 } }

Intimidate.merge { damage_instance { ai_base_score 70 } } // Applique Peur, excellent debuff défensif.
Intimidate2.merge { damage_instance { ai_base_score 70 } }

BodyGuard.merge { damage_instance { ai_base_score 85 } } // Permet d'encaisser à la place d'un allié.
BodyGuard2.merge { damage_instance { ai_base_score 85 } }


// --- 2. GESTION DES REPOUSSEMENTS LOURDS ET CONTRÔLE DE FOULE ---
// Si un Boss est trop proche, le Tank doit l'envoyer valser au loin.
Toss.merge { damage_instance { ai_base_score 60 } }
Toss2.merge { damage_instance { ai_base_score 60 } }
BonusToss.merge { damage_instance { ai_base_score 60 } }
BonusToss2.merge { damage_instance { ai_base_score 60 } }
NubbyToss.merge { damage_instance { ai_base_score 60 } }
NubbyToss2.merge { damage_instance { ai_base_score 60 } }

BatterUp.merge { damage_instance { ai_base_score 50 } } // Énorme recul.
BatterUp2.merge { damage_instance { ai_base_score 50 } }

Suplex.merge { damage_instance { ai_base_score 45 } } // Immobilise et déplace.
Suplex2.merge { damage_instance { ai_base_score 45 } }

RockTomb.merge { damage_instance { ai_base_score 65 } } // Pétrifie (étourdissement solide).
RockTomb2.merge { damage_instance { ai_base_score 65 } }

Fissure.merge { damage_instance { ai_base_score 65 } } // Pétrifie en zone.
Fissure2.merge { damage_instance { ai_base_score 65 } }

StoneGaze.merge { damage_instance { ai_base_score 65 } } // Pétrifie en ligne.
StoneGaze2.merge { damage_instance { ai_base_score 65 } }

Medusa.merge { damage_instance { ai_base_score 70 } } // AoE massive de pétrification.
Medusa2.merge { damage_instance { ai_base_score 70 } }


// --- 3. VÉRIFICATION DE FRAPPE LÉTALE (MÊLÉE) ---
// Le Tank ne doit frapper un Boss au corps-à-corps QUE s'il peut l'achever.
HeadButt.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 1 } Else { FlatAIBonus -999999 } } } } } }
HeadButt2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }

Chew.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
Chew2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }

BackBreaker.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 3 } Else { FlatAIBonus -999999 } } } } } }
BackBreaker2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 3 } Else { FlatAIBonus -999999 } } } } } }

Gore.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 2 } Else { FlatAIBonus -999999 } } } } } }
Gore2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 4 } Else { FlatAIBonus -999999 } } } } } }

Lunge.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
Lunge2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }

Nudge.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 0 } Else { FlatAIBonus -999999 } } } } } }
Nudge2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 0 } Else { FlatAIBonus -999999 } } } } } }

// FullForce dépend de la constitution (CON) du lanceur, difficile à prévoir précisément, on interdit sur les Boss sauf si on est très sûr.
FullForce.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
FullForce2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }


// --- 4. DÉSACTIVATION DES SORTS AUTO-DESTRUCTEURS OU CASSANT LE POSITIONNEMENT ---
// TankTantrum crée des rochers aléatoires qui peuvent blesser l'équipe et bloquer les chemins.
TankTantrum.merge { damage_instance { ai_base_score -99999 } }
TankTantrum2.merge { damage_instance { ai_base_score -99999 } }

// BellyFlop et CatapultJump sont des sauts qui vont isoler le Tank au milieu des ennemis, 
// brisant sa ligne de front et exposant le reste du groupe.
BellyFlop.merge { damage_instance { ai_base_score -99999 } }
BellyFlop2.merge { damage_instance { ai_base_score -99999 } }
CatapultJump.merge { damage_instance { ai_base_score -99999 } }
CatapultJump2.merge { damage_instance { ai_base_score -99999 } }
FlipFlop.merge { damage_instance { ai_base_score -99999 } }
FlipFlop2.merge { damage_instance { ai_base_score -99999 } }

// TankSwap peut échanger sa place avec le Mage ou le Chasseur, les mettant en première ligne ! Fatal.
TankSwap.merge { damage_instance { ai_base_score -99999 } }
TankSwap2.merge { damage_instance { ai_base_score -99999 } }


// --- 5. GESTION DES BUFFS ET DE LA DÉFENSE (Score modéré) ---
// L'IA les utilisera s'il n'y a pas d'urgence à repousser un ennemi ou à provoquer.
ThrowShield.merge { damage_instance { ai_base_score 30 custom_additional_ai_weight favor_if_unshielded } }
ThrowShield2.merge { damage_instance { ai_base_score 30 custom_additional_ai_weight favor_if_unshielded } }

ChewCud.merge { damage_instance { ai_base_score 20 custom_additional_ai_weight must_heal_most_missing_health } }
ChewCud2.merge { damage_instance { ai_base_score 20 custom_additional_ai_weight must_heal_most_missing_health } }

Supper.merge { damage_instance { ai_base_score 25 custom_additional_ai_weight must_heal_most_missing_health } }
Supper2.merge { damage_instance { ai_base_score 25 custom_additional_ai_weight must_heal_most_missing_health } }

PlantFeet.merge { damage_instance { ai_base_score 20 custom_additional_ai_weight favor_if_unshielded } }
PlantFeet2.merge { damage_instance { ai_base_score 20 custom_additional_ai_weight favor_if_unshielded } }

Spur.merge { damage_instance { ai_base_score 20 effects { Conditional_Speculative { Conditional_SourceHasStatus { status Thorns FlatAIBonus -999999 } } } } }
Spur2.merge { damage_instance { ai_base_score 20 effects { Conditional_Speculative { Conditional_SourceHasStatus { status Thorns FlatAIBonus -999999 } } } } }

Thicken.merge { damage_instance { ai_base_score 15 } }
Thicken2.merge { damage_instance { ai_base_score 15 } }

// BarbedWire, Anchor et SteelSkin sont des buffs utiles mais qui ont un risque de spam. 
// Les pénalités d'origine (-10 / -999) sont un peu fortes. On les équilibre à 0 pour une utilisation normale.
BarbedWire.merge { damage_instance { ai_base_score 30 custom_additional_ai_weight tile_close_to_enemy effects { Conditional_Speculative { Conditional_SourceHasStatus { status Thorns FlatAIBonus -999999 } } } } }
BarbedWire2.merge { damage_instance { ai_base_score 30 custom_additional_ai_weight tile_close_to_enemy effects { Conditional_Speculative { Conditional_SourceHasStatus { status Thorns FlatAIBonus -999999 } } } } }

// Anchor donne Ancrage (Brace). Ne se lance que si l'ennemi est proche ET qu'il n'a pas déjà Brace.
Anchor.merge { damage_instance { ai_base_score 30 custom_additional_ai_weight tile_close_to_enemy effects { Conditional_Speculative { Conditional_SourceHasStatus { status Brace FlatAIBonus -999999 } } } } }
Anchor2.merge { damage_instance { ai_base_score 30 custom_additional_ai_weight tile_close_to_enemy effects { Conditional_Speculative { Conditional_SourceHasStatus { status Brace FlatAIBonus -999999 } } } } }

// SteelSkin donne Ancrage (Brace). Pareil, sécurité anti-spam.
SteelSkin.merge { damage_instance { ai_base_score 30 effects { Conditional_Speculative { Conditional_SourceHasStatus { status Brace FlatAIBonus -999999 } } } } }
SteelSkin2.merge { damage_instance { ai_base_score 30 effects { Conditional_Speculative { Conditional_SourceHasStatus { status Brace FlatAIBonus -999999 } } } } }


