// Tank abilities AI patches
// BarbedWire: Thorns stackable, expires after 1 turn expires_on_appliers_turn true
// tile_close_to_enemy: useless without adjacent enemy
// ai_base_score -15: strongly discourages spam -- offense should always score higher
BarbedWire.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
        ai_base_score -15
    }
}

// BarbedWire2: same logic, range 20 instead of 5
BarbedWire2.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
        ai_base_score -15
    }
}
