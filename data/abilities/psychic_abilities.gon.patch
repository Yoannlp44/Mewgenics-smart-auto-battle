// =====================================================================
// PATCH OPTIMISÉ DE L'IA DU PSYCHIC - MAÎTRE DU CONTRÔLE DE TERRAIN
// =====================================================================

// --- 1. DÉSACTIVATION DES SORTS CHAOTIQUES ET TÉLÉPORTATIONS ALÉATOIRES ---
// Ces capacités mélangent les positions de tout le monde. Si un Boss est téléporté 
// au milieu de l'équipe (ou un allié fragile téléporté devant le Boss), c'est fini.
RealityScramble.merge { damage_instance { ai_base_score -99999 } }
RealityScramble2.merge { damage_instance { ai_base_score -99999 } }

ChaosSwap2.merge { damage_instance { ai_base_score -99999 } }

// Bump et Flicker téléportent une cible. C'est trop risqué algorithmiquement de laisser 
// l'IA décider où envoyer un allié ou un ennemi.
Flicker.merge { damage_instance { ai_base_score -99999 } }
Flicker2.merge { damage_instance { ai_base_score -99999 } }


// --- 2. PROTECTION DE L'ÉQUIPE (ANTI-TIR AMI MENTAL) ---
// Ces sorts de zone touchent tout le monde, y compris les alliés, et appliquent des 
// statuts destructeurs (Folie, Aveuglement). L'IA native ne calcule pas bien le ratio "Bénéfice/Risque".
MindCrack.merge { damage_instance { ai_base_score -99999 } }
MindCrack2.merge { damage_instance { ai_base_score -99999 } }

MindBlast.merge { damage_instance { ai_base_score -99999 } }
MindBlast2.merge { damage_instance { ai_base_score -99999 } }

MassHysteria.merge { damage_instance { ai_base_score -99999 } }
MassHysteria2.merge { damage_instance { ai_base_score -99999 } }

Supernova.merge { damage_instance { ai_base_score -99999 } }
Supernova2.merge { damage_instance { ai_base_score -99999 } }

MassManaLeech.merge { damage_instance { ai_base_score -99999 } }
MassManaLeech2.merge { damage_instance { ai_base_score -99999 } }

BlindingFlash.merge { damage_instance { ai_base_score -99999 } } // Le niveau 1 aveugle les alliés
BlindingFlash2.merge { damage_instance { ai_base_score 0 } } // Le niveau 2 exclut les alliés, il est sûr.

// Glare rend la cible Folle (Madness) mais n'a pas de restriction. Si lancé sur un allié...
Glare.merge { damage_instance { ai_base_score -99999 } }
Glare2.merge { damage_instance { ai_base_score -99999 } }


// --- 3. INTERDICTION DES SORTS QUI FONT PASSER LE TOUR (SUICIDE) ---
// "Pass", "ThinkDeep" et "ExtraTurnQuestion" endorment ou étourdissent le lanceur. 
// Face à un vaporisateur, perdre un tour équivaut à la mort.
Pass.merge { damage_instance { ai_base_score -99999 } }
Pass2.merge { damage_instance { ai_base_score -99999 } }

ThinkDeep.merge { damage_instance { ai_base_score -99999 } }
ThinkDeep2.merge { damage_instance { ai_base_score -99999 } }

ExtraTurnQuestion.merge { damage_instance { ai_base_score -99999 } }
ExtraTurnQuestion2.merge { damage_instance { ai_base_score -99999 } }


// --- 4. PRIORISATION DU CONTRÔLE DE FOULE (CROWD CONTROL) ---
// Ces capacités réduisent le rayon d'action des boss ou les retournent. Ce sont des priorités absolues.
Stasis.merge { damage_instance { ai_base_score 80 custom_additional_ai_weight avoid_redundant_debuffs } }
Stasis2.merge { damage_instance { ai_base_score 80 custom_additional_ai_weight avoid_redundant_debuffs } }

MindControl.merge { damage_instance { ai_base_score 75 custom_additional_ai_weight avoid_redundant_debuffs_strict } }
MindControl2.merge { damage_instance { ai_base_score 75 custom_additional_ai_weight avoid_redundant_debuffs_strict } }

Puppet.merge { damage_instance { ai_base_score 70 custom_additional_ai_weight avoid_redundant_debuffs } }
Puppet2.merge { damage_instance { ai_base_score 70 custom_additional_ai_weight avoid_redundant_debuffs } }

IncreaseGravity.merge { damage_instance { ai_base_score 65 } } // Immobilise ou Ralentit
IncreaseGravity2.merge { damage_instance { ai_base_score 65 } }


// --- 5. GESTION DES REPOUSSEMENTS MAJEURS (SURVIE) ---
// Le Psychic excelle pour repousser les boss loin de l'équipe (Kiting de zone).
Telekinesis.merge { damage_instance { ai_base_score 60 } }
Telekinesis2.merge { damage_instance { ai_base_score 60 } }

ForceBlast.merge { damage_instance { ai_base_score 60 } }
ForceBlast2.merge { damage_instance { ai_base_score 60 } }

ForceCone.merge { damage_instance { ai_base_score 55 } }
ForceCone2.merge { damage_instance { ai_base_score 55 } }

// Vaccuum peut être utile pour regrouper les ennemis avant une attaque AoE du Mage.
Vaccuum.merge { damage_instance { ai_base_score 50 } }
Vaccuum2.merge { damage_instance { ai_base_score 50 } }


