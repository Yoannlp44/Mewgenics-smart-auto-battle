// --- 1. INTERDICTION DES FRAPPES DE MÊLÉE ET SUICIDES LÉTALS ---
// La règle "kill_enemy 100" dans les decisions suffit. On met juste le score de base à 0 ou on interdit les pires.

Shatter.merge {
    damage_instance {
        ai_base_score 0
    }
}
Shatter2.merge {
    damage_instance {
        ai_base_score 0
    }
}

// Telefrag téléporte sur la cible. Interdiction stricte.
Telefrag.merge {
    damage_instance {
        ai_base_score -99999
    }
}
Telefrag2.merge {
    damage_instance {
        ai_base_score -99999
    }
}


