// --- 4. DÉSACTIVATION DES SUICIDES ---
// "Meditate" endort le moine (Sleep 8 !). Devant un boss, c'est l'annihilation. À DÉSACTIVER.
Meditate.merge { damage_instance { ai_base_score -99999 } }
Meditate2.merge { damage_instance { ai_base_score -99999 } }

// "DoomPunch" applique le statut Doomed (mort après X tours). Sur un boss, ça endort le moine. À DÉSACTIVER contre les Boss.
DoomPunch.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }
DoomPunch2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }

// DeepDive tue littéralement le lanceur (SafeDie 1) pour le ressusciter. L'IA gère mal ce risque de fin de tour.
DeepDive.merge { damage_instance { ai_base_score -99999 } }
