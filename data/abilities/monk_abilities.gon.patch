// =====================================================================
// PATCH OPTIMISÉ DE L'IA DU MONK - MAÎTRE DES ARTS MARTIAUX ET DU KI
// =====================================================================

// --- 1. FONCTION DE VÉRIFICATION LÉTALE (ATTAQUES DE MÊLÉE) ---
// Le Moine est un combattant agile mais fragile. Il ne doit engager les boss 
// au corps-à-corps QUE s'il peut garantir une exécution.

// Attaques de base (Seuil de 5)
Propell.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
Propell2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }

ComboThrow.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
ComboThrow2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }

// Attaques lourdes (Seuil de 10)
DragonPunch.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 10 } Else { FlatAIBonus -999999 } } } } } }
DragonPunch2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 10 } Else { FlatAIBonus -999999 } } } } } }

// Dash et Lunge (Seuils variables basés sur la mêlée)
UnimpededLunge.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
UnimpededLunge2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }

// OnePunch (Instakill potentiel) - Autorisé si PV du boss < 25 (Exécution absolue).
OnePunch.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 25 } Else { FlatAIBonus -999999 } } } } } }
OnePunch2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 25 } Else { FlatAIBonus -999999 } } } } } }


// --- 2. GESTION DES REPOUSSEMENTS ET CONTRÔLE (SURVIE) ---
// Si l'IA ne peut pas tuer un boss au corps-à-corps, elle doit chercher à le repousser ou le bloquer.

// HipToss (Projection) - Excellent pour éloigner une menace.
HipToss.merge { damage_instance { ai_base_score 60 } }
HipToss2.merge { damage_instance { ai_base_score 60 } }

// FlyingFist (Repoussement de zone).
FlyingFist.merge { damage_instance { ai_base_score 50 } }
FlyingFist2.merge { damage_instance { ai_base_score 50 } }


