// =====================================================================
// PATCH OPTIMISÉ DE L'IA DU BUTCHER - EXÉCUTEUR ET LANCEUR LOURD
// =====================================================================

// --- 1. FONCTION DE VÉRIFICATION LÉTALE (MÊLÉE & SUICIDE POTENTIEL) ---
// Le Boucher ne doit s'engager au corps-à-corps contre un Boss QUE si l'exécution est garantie.
// S'il survit, le Boucher prendra la punition fatale.

// Mutilate (1 Dégât x 3 coups = Seuil de 3)
Mutilate.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 3 } Else { FlatAIBonus -999999 } } } } } }
Mutilate2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 3 } Else { FlatAIBonus -999999 } } } } } }

// Shred (1 Dégât x 5 coups = Seuil de 5)
Shred.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
Shred2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }

// Chomp (Seuil de 5)
Chomp.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
Chomp2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }

// SliceAndDice (Seuil de 2)
SliceAndDice.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 2 } Else { FlatAIBonus -999999 } } } } } }
SliceAndDice2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 2 } Else { FlatAIBonus -999999 } } } } } }

// Gib (Seuil de 3 / 6)
Gib.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 3 } Else { FlatAIBonus -999999 } } } } } }
Gib2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 6 } Else { FlatAIBonus -999999 } } } } } }

// Monch scale sur les PV. Dans le doute face à un boss, on interdit sauf s'il lui reste très peu de vie (Seuil arbitraire de 10).
Monch.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 10 } Else { FlatAIBonus -999999 } } } } } }
Monch2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 10 } Else { FlatAIBonus -999999 } } } } } }


// --- 2. GESTION DES REPOUSSEMENTS (BOUTONS D'URGENCE) ---
// Si l'IA ne peut pas tuer le Boss, elle cherchera l'action avec le plus haut score.
// On gonfle les scores des capacités qui repoussent l'ennemi pour protéger le Boucher !

// RoughToss "jette" l'ennemi très loin. Parfait pour se sauver d'un Carnibulb.
RoughToss.merge { damage_instance { ai_base_score 60 } }
RoughToss2.merge { damage_instance { ai_base_score 60 } }

// Burp applique "ForceMoveAway", forçant l'ennemi à reculer.
Burp.merge { damage_instance { ai_base_score 50 } }
Burp2.merge { damage_instance { ai_base_score 50 } }

// Crushinator inflige un énorme Knockback (recul) si la cible n'a pas de bouclier !
Crushinator.merge { damage_instance { ai_base_score 40 } }
Crushinator2.merge { damage_instance { ai_base_score 50 } }

// BadGas pousse le Boucher lui-même en arrière, lui permettant de fuir un corps-à-corps.
BadGas.merge { damage_instance { ai_base_score 40 } }
BadGas2.merge { damage_instance { ai_base_score 40 } }


// --- 3. BANISSEMENT DES SUICIDES ET ERREURS D'IA ---
// ForceFeed soigne la cible... l'IA va s'en servir pour soigner les ennemis. A DÉSACTIVER.
ForceFeed.merge { damage_instance { ai_base_score -99999 } }
ForceFeed2.merge { damage_instance { ai_base_score -99999 } }

// SkullBash étourdit le Boucher. Face à un boss, s'il rate son coup, il est mort à 100%. A BANIR sur les boss.
SkullBash.merge { damage_instance { ai_base_score -20 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }
SkullBash2.merge { damage_instance { ai_base_score -10 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }

// BodySlam sacrifie 25% des PV du Boucher pour sauter dans la mêlée. Trop dangereux contre un boss.
BodySlam.merge { damage_instance { ai_base_score -5 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }
BodySlam2.merge { damage_instance { ai_base_score -5 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }

// Ces sorts endorment le boucher, volent le tour d'un allié, ou le tuent.
TaintedOffering.merge { damage_instance { ai_base_score -99999 } }
TaintedOffering2.merge { damage_instance { ai_base_score 0 } } // Le niveau 2 n'endort pas, on le laisse à 0.
Tryptophan.merge { damage_instance { ai_base_score -99999 } }
Tryptophan2.merge { damage_instance { ai_base_score -99999 } }
MyTurn.merge { damage_instance { ai_base_score -99999 } }
MyTurn2.merge { damage_instance { ai_base_score -99999 } }
Butcher.merge { damage_instance { ai_base_score -99999 } } // Instakill de zone qui peut tuer les alliés.
Butcher2.merge { damage_instance { ai_base_score -99999 } }


