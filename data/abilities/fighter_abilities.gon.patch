// Fighter abilities AI patches

// ChaosRampage: TakeBonusTurnWithStatus Madness 1 Confusion 1 -- gains extra turn but becomes confused and mad
// Never use in auto-battle: friendly-fire guaranteed
ChaosRampage.merge {
    damage_instance {
        ai_base_score -99999
    }
}

// ChaosRampage2: variant of ChaosRampage, same issue
ChaosRampage2.merge {
    damage_instance {
        ai_base_score -99999
    }
}

// Enrage: applies StrengthUp + Confusion to self -- confusion causes friendly-fire
Enrage.merge {
    damage_instance {
        ai_base_score -99999
    }
}

// Enrage2: variant_of Enrage with no damage_instance of its own -- inherits from Enrage, cannot patch

