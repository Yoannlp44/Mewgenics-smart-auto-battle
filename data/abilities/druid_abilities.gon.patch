// Druid abilities AI patches
// ChaChaSlide: AoE knockback with RandomKnockbackDirection -- randomly displaces ALL units including allies
ChaChaSlide.merge {
    damage_instance {
        ai_base_score -99999
    }
}

// ChaChaSlide2: variant of ChaChaSlide, same friendly-fire risk
ChaChaSlide2.merge {
    damage_instance {
        ai_base_score -99999
    }
}

// HardenSkin: Shield+Thorns+Brace stackable, expires after 1 turn expires_on_appliers_turn true
// tile_close_to_enemy: useless without adjacent enemy
// ai_base_score -15: strongly discourages spam
HardenSkin.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
        ai_base_score -15
    }
}

// HardenSkin2: same logic
HardenSkin2.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
        ai_base_score -15
    }
}
