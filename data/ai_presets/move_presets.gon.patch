}


// --- LA LIGNE DE FRONT ET LE SOUTIEN ---
// Objectif : Le Tank bloque physiquement, le Clerc se cache derrière lui.

smart_tank_move.merge {
    // Poussé à -2 pour forcer le contact et bloquer les couloirs
    distance_to_enemy -2
    distance_to_ally -1
    distance_to_character 0
    preferred_distance 0
    total_distance_moved 0.01
    face_closest_enemy 1
    // Ajusté à 1.5 : protège l'équipe mais ne se suicide pas sur un Death Worm
    danger_avoidance 1.5
}

smart_cleric_move.merge {
    distance_to_enemy 1
    distance_to_ally -2
    distance_to_character 0
    preferred_distance 2
    total_distance_moved 0.01
    face_closest_enemy 0
    danger_avoidance 5
}


