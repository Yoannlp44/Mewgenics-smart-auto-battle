smart_hunter_move.merge {
    distance_to_enemy -1
    distance_to_ally 0
    distance_to_character 0
    // max weapon range
    preferred_distance reach
    total_distance_moved 0.01
    face_closest_enemy 1
    // stays at range, avoids dangerous tiles
    danger_avoidance 3
    // hides in tall grass when possible
    tall_grass 1
}

