// --- LES SPÉCIALISTES DU HARCÈLEMENT (KITING) ---
// Objectif : Maintenir la cible à la bordure absolue de la portée pour fuir les entités à 3 mouvements (ex: Carnibulb).

smart_hunter_move.merge {
    distance_to_enemy 2
    distance_to_ally 0
    distance_to_character 0
    // Utilisation de mov+reach (inspiré de keep_max_ranged_distance ) pour reculer tout en tirant
    preferred_distance mov+reach
    total_distance_moved 0.01
    face_closest_enemy 1
    danger_avoidance 3
    // Augmenté à 5 (inspiré de prefer_tall_grass_always_move [cite: 6]) pour maximiser l'esquive
    tall_grass 5
}

smart_mage_move.merge {
    distance_to_enemy 2
    distance_to_ally 0
    distance_to_character 0
    // Kiting maximal 
    preferred_distance mov+reach
    total_distance_moved 0.01
    face_closest_enemy 1
    danger_avoidance 3
}

smart_psychic_move.merge {
    distance_to_enemy 3
    distance_to_ally -1
